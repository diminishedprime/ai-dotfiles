{
  "attribution": {
    "commit": ""
  },
  "permissions": {
    "allow": [
      "Write(~/worktree-features/*.md)",
      "Edit(~/worktree-features/*.md)",
      "Read(~/.claude/skills/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/pre-tool-use.sh"
          }
        ]
      },
      {
        "matcher": "Read|WebFetch|WebSearch|Write|Edit|Task|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/log-read.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read|WebFetch|WebSearch|Write|Edit|Task|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/log-read.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "command -v prettier >/dev/null 2>&1 || exit 0; jq -r '.tool_input.file_path // empty' | { read -r f; case \"$f\" in *.md) prettier --prose-wrap always --write \"$f\" ;; esac; } 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "effortLevel": "medium",
  "theme": "auto"
}
